# ═══════════════════════════════════════════════════════════════════════════
# SUNAT Parser API - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your real values.
# The .env file must NOT be committed to version control.
# ═══════════════════════════════════════════════════════════════════════════

# ── Cloudflare R2 (S3-compatible Object Storage) ──────────────────────────
S3_BUCKET_NAME=app-bucket
S3_ACCESS_KEY=your_r2_access_key
S3_SECRET_KEY=your_r2_secret_key
S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
S3_REGION=auto

# ── API Security ──────────────────────────────────────────────────────────
API_SECRET_KEY=your_api_secret_key_here

# ── Uvicorn Server (Optional, defaults shown) ─────────────────────────────
# API_HOST=0.0.0.0
# API_PORT=8000

# ── Database (PostgreSQL) ─────────────────────────────────────────────────
DB_URI=postgresql://user:password@localhost:5432/parser_sunat

# ── Pipeline Performance (Optional, defaults shown) ───────────────────────
# MAX_WORKERS=10